# Managed by Ansible — do not edit manually
# Traefik - OVH DNS challenge
OVH_APPLICATION_KEY={{ ovh_application_key }}
OVH_APPLICATION_SECRET={{ ovh_application_secret }}
OVH_CONSUMER_KEY={{ ovh_consumer_key }}
# Traefik - CrowdSec bouncer
CROWDSEC_API_KEY={{ crowdsec_api_key | default('changeme-after-bootstrap', true) }}
# CrowdSec enrollment
ENROLL_KEY={{ crowdsec_enroll_key | default('', true) }}
# GeoIP updates
GEOIPUPDATE_ACCOUNT_ID={{ maxmind_user_id | default('', true) }}
GEOIPUPDATE_LICENSE_KEY={{ maxmind_license_key | default('', true) }}
# Prometheus basic auth (user:bcrypt_hash)
PROMETHEUS_BASIC_AUTH={{ prometheus_basic_auth | default('', true) }}
# Authentik outpost token (for forward auth proxy)
AUTHENTIK_TOKEN={{ authentik_outpost_token | default('', true) }}
# Infisical machine identity (for cert-refresh container)
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID={{ infisical_universal_auth_client_id | default('', true) }}
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET={{ infisical_universal_auth_client_secret | default('', true) }}
