{
	# No ACME on the NAS — we serve the cluster's *.vzkn.eu wildcard, synced to
	# /certs by the host cert-sync script. Each site pins it explicitly below.
	auto_https off

	servers {
		listener_wrappers {
			proxy_protocol {
				allow 172.16.0.0/12
			}
			tls
		}
	}
}

# Proxy by HOST IP:port (not container name) on purpose: Caddy then works the
# same whether an app is still plugin-managed or already migrated to doco-cd —
# both publish the same host port. Decouples the migration order. 10.10.0.11 = Aincrad.

(tls_wildcard) {
	tls /certs/wildcard.crt /certs/wildcard.key
}

(block_world) {
	@block not remote_ip private_ranges
	abort @block
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains;"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin"
		X-Robots-Tag "noindex, nofollow, nosnippet, noarchive"
	}
}

# === media (external via towonel agent) =================================
emby.vzkn.eu {
	import tls_wildcard
	import security_headers
	reverse_proxy 10.10.0.11:8096
}

music.vzkn.eu {
	import tls_wildcard
	import security_headers
	reverse_proxy 10.10.0.11:8080
}

