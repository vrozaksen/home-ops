{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": ["Process terraform files"],
      "matchManagers": ["terraform"],
      "matchDatasources": ["terraform-provider"],
      "versioning": "terraform",
      "matchPackagePatterns": [".*"]
    },
    {
      "description": "Tekton operator uses prefixed git tags (tekton-operator-X.Y.Z)",
      "matchManagers": ["flux"],
      "matchDepNames": ["tektoncd/operator"],
      "extractVersion": "^tekton-operator-(?<version>.+)$"
    },
    {
      "description": "Bambuddy uses 4-segment versions (0.2.4.2) — needs loose versioning; skip beta tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/maziggy/bambuddy"],
      "versioning": "loose",
      "ignoreUnstable": true,
      "allowedVersions": "!/b\\d+$/"
    },
    {
      "description": "Mautrix bridges: pin to v0.YYMM.X scheme (CalVer alias tags vYY.MM.X order INCORRECTLY under semver and would cause downgrades, e.g. v26.02.2 < v0.2605.0 by date but > by semver)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "dock.mau.dev/mautrix/signal",
        "dock.mau.dev/mautrix/meta",
        "dock.mau.dev/mautrix/discord",
        "dock.mau.dev/mautrix/whatsapp",
        "dock.mau.dev/mautrix/telegram"
      ],
      "allowedVersions": "/^v0\\.\\d+\\.\\d+$/"
    }
  ]
}
