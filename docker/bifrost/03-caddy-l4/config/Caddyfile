{
	email {$CADDY_ACME_EMAIL}
	http_port 8080
	https_port 8443

	# DNS-01 ACME via OVH (works through layer4 indirection)
	acme_dns ovh {
		endpoint {$OVH_ENDPOINT}
		application_key {$OVH_APPLICATION_KEY}
		application_secret {$OVH_APPLICATION_SECRET}
		consumer_key {$OVH_CONSUMER_KEY}
	}

	layer4 {
		:443 {
			@relay tls sni relay.towonel.vzkn.eu
			route @relay {
				proxy {
					upstream iroh-relay:8443
				}
			}
			@local tls sni {$VPS_LOCAL_HOSTS}
			route @local {
				proxy {
					proxy_protocol v2
					upstream 127.0.0.1:8443
				}
			}
			@tls tls
			route @tls {
				proxy {
					proxy_protocol v2
					upstream towonel-hub:4443
				}
			}
		}
		:80 {
			@local_http http host {$VPS_LOCAL_HOSTS}
			route @local_http {
				proxy {
					proxy_protocol v2
					upstream 127.0.0.1:8080
				}
			}
			@http http
			route @http {
				proxy towonel-hub:8081
			}
		}
	}

	servers :8443 {
		listener_wrappers {
			proxy_protocol {
				timeout 2s
				allow 127.0.0.1/32
			}
			tls
		}
	}
	servers :8080 {
		listener_wrappers {
			proxy_protocol {
				timeout 2s
				allow 127.0.0.1/32
			}
		}
	}
}

bifrost-doco-cd.vzkn.eu {
	reverse_proxy doco-cd:8880
}

bifrost-gatus.vzkn.eu {
	reverse_proxy gatus:8080
}

bifrost.vzkn.eu {
	handle /metrics {
		basic_auth {
			prometheus {$BIFROST_METRICS_BCRYPT}
		}
		reverse_proxy node-exporter:9100
	}
	handle {
		respond 404
	}
}

tunnel.vzkn.eu {
	reverse_proxy towonel-hub:8443
}

twnl.vzkn.eu {
	reverse_proxy towonel-hub:8443
}
