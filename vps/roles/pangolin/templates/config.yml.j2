gerbil:
    start_port: 51820
    base_endpoint: "{{ pangolin_hostname }}"
app:
    dashboard_url: "https://{{ pangolin_hostname }}"
    log_level: "info"
    telemetry:
        anonymous_usage: false
domains:
    domain1:
        base_domain: "{{ pangolin_domain }}"
        cert_resolver: "letsencrypt"
server:
    integration_port: 3003
    secret: "{{ pangolin_secret }}"
    cors:
        origins: ["https://{{ pangolin_hostname }}"]
        methods: ["GET", "POST", "PUT", "DELETE", "PATCH"]
        allowed_headers: ["X-CSRF-Token", "Content-Type"]
        credentials: false
    maxmind_db_path: "./config/GeoLite2/GeoLite2-Country.mmdb"
    maxmind_asn_path: "./config/GeoLite2/GeoLite2-ASN.mmdb"
flags:
    require_email_verification: false
    disable_signup_without_invite: true
    disable_user_create_org: false
    allow_raw_resources: true
    enable_integration_api: true
